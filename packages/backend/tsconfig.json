{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "es2023",
    "module": "node20",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"]
}
